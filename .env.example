# PostgreSQL (also used for pgvector RAG store)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/agentdb

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Voice
WHISPER_MODEL=base
VOICE_MODE=push_to_talk   # push_to_talk | continuous

# RAG
DOCS_DIR=./docs
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production

# Auth (JWT)
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
